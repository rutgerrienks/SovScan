# Port for the backend server to listen on
PORT=3001

# Database connection details for local docker-compose setup
# For Kubernetes, these are injected via secrets and will override these values.
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_local_db_password
DB_NAME=dsh_data
DB_SSL=false

# Scaleway credentials for registry login (optional, can be passed as environment variables)
SCW_SECRET_KEY=""
SCW_PUBLIC_KEY=""
